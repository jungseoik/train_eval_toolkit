# =============================================================
# vLLM Serving 환경 설정
# 이 파일을 .env 로 복사한 뒤 환경에 맞게 수정하세요.
#   cp .env.example .env
# =============================================================

# ── 모델 설정 ──
# HuggingFace 모델 ID (컨테이너 시작 시 자동 다운로드)
MODEL_NAME=Qwen/Qwen3.5-2B

# ── GPU 설정 ──
# GPU 아키텍처에 맞는 베이스 이미지 선택
#   Blackwell (B200 등):          vllm/vllm-openai:cu130-nightly
#   Hopper / Ampere (H100, A100): vllm/vllm-openai:latest
VLLM_IMAGE=vllm/vllm-openai:latest

# 사용할 GPU ID (예: "0,1" 또는 "all")
NVIDIA_VISIBLE_DEVICES=all

# Tensor Parallelism: 사용할 GPU 수 (예: 2장이면 2)
TENSOR_PARALLEL_SIZE=1

# ── 서버 설정 ──
# 호스트에서 접근할 포트
HOST_PORT=8000

# ── vLLM 엔진 설정 ──
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=128
MAX_NUM_BATCHED_TOKENS=131072
GPU_MEMORY_UTILIZATION=0.9

# KV Cache 메모리 상한 (GPU VRAM에 맞게 조정)
# 설정하지 않으면 vLLM이 자동 계산 (gpu_memory_utilization 기반)
# 이미지 1장 + 짧은 응답 용도면 2~3G로 충분
# KV_CACHE_MEMORY_BYTES=2G

# ── HuggingFace 토큰 (선택) ──
# 비공개(gated) 모델 다운로드 시 필요
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 추가 vLLM 인자 (선택) ──
# 공백으로 구분하여 추가 인자를 넣을 수 있음
# 예: --enable-prefix-caching --reasoning-parser qwen3
EXTRA_VLLM_ARGS=
